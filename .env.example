# Environment Variables for Estudiante Elite

# ============================================
# AI PROVIDER SELECTION
# ============================================
# Selecciona el modelo de IA a utilizar
# Valores: "gemini" | "openai"
AI_PROVIDER=gemini

# ============================================
# GEMINI (Google AI)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_FILESEARCH_STORE_ID=fileSearchStores/your_store_id

# ============================================
# OPENAI (ChatGPT)
# ============================================
# API Key de OpenAI
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ID del Assistant pre-configurado con File Search (para Quiz/Exam)
OPENAI_ASSISTANT_ID=asst_your_assistant_id

# ID del Vector Store para documentos RAG (requerido para GPT-5.2)
OPENAI_VECTOR_STORE_ID=vs_your_vector_store_id

# Modelo a utilizar para Quiz/Exam con Assistants API (JSON mode)
# NOTA: Chat conversacional usa GPT-5.2 vía Responses API
OPENAI_MODEL=gpt-4o

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# E2E TESTING (Playwright)
# ============================================
# Usuario de prueba para tests E2E autenticados.
# Créalo en Supabase Auth manualmente o deja que global-setup lo cree.
# Nunca uses credenciales reales de usuario en estas vars.
TEST_USER_EMAIL=e2e-test@lextutor.dev
TEST_USER_PASSWORD=TestPassword123!

# ============================================
# DEVELOPMENT TOOLS (solo en .env.local, nunca en .env)
# ============================================
# Token personal para el MCP de Supabase (Claude Code → producción).
# Crear en: https://supabase.com/dashboard/account/tokens
# Añadir a .env.local (gitignored), NO a .env
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxx
# SUPABASE_PROJECT_ID=your_project_ref  # opcional, para escopar al proyecto

# Personal Access Token para el MCP de GitHub (Claude Code → crear/mergear PRs,
# comentar issues, leer CI). Crear classic PAT en:
#   https://github.com/settings/tokens/new
# Scopes: repo, workflow, read:org
# Añadir a .env.local (gitignored), NO a .env
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
