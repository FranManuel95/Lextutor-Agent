# Environment Variables for Estudiante Elite

# ============================================
# AI PROVIDER SELECTION
# ============================================
# Selecciona el modelo de IA a utilizar
# Valores: "gemini" | "openai"
AI_PROVIDER=gemini

# ============================================
# GEMINI (Google AI)
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_FILESEARCH_STORE_ID=fileSearchStores/your_store_id

# ============================================
# OPENAI (ChatGPT)
# ============================================
# API Key de OpenAI
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# ID del Assistant pre-configurado con File Search
OPENAI_ASSISTANT_ID=asst_your_assistant_id

# ID del Vector Store para documentos RAG
OPENAI_VECTOR_STORE_ID=vs_your_vector_store_id

# Modelo a utilizar (opcional, por defecto: gpt-4o-mini)
# Opciones: gpt-4o-mini, gpt-4o, gpt-5.2 (si está disponible)
OPENAI_MODEL=gpt-4o-mini

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
